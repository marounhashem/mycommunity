generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────
// Enums
// ──────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  OWNER
}

enum InvoiceStatus {
  UNPAID
  PAID
  OVERDUE
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Audience {
  ALL
  ZONE
  UNIT
}

// ──────────────────────────────────────
// Models
// ──────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  role            Role     @default(OWNER)
  hashedPassword  String   @map("hashed_password")
  createdAt       DateTime @default(now()) @map("created_at")

  ownedUnits      Unit[]             @relation("UnitOwner")
  owners          Owner[]
  assignedTickets Ticket[]           @relation("AssignedTickets")
  ticketComments  TicketComment[]
  announcements   Announcement[]
  approvedRenovations RenovationApplication[] @relation("ApprovedRenovations")

  @@map("users")
}

model Unit {
  id         String  @id @default(cuid())
  unitNumber String  @map("unit_number")
  zone       String
  sqft       Int
  ownerId    String? @map("owner_id")

  owner      User?   @relation("UnitOwner", fields: [ownerId], references: [id])
  owners     Owner[]
  invoices   Invoice[]
  tickets    Ticket[]
  renovationApplications RenovationApplication[]
  violations Violation[]

  @@map("units")
}

model Owner {
  id     String @id @default(cuid())
  userId String @map("user_id")
  unitId String @map("unit_id")
  phone  String

  user   User   @relation(fields: [userId], references: [id])
  unit   Unit   @relation(fields: [unitId], references: [id])

  @@map("owners")
}

model Invoice {
  id        String        @id @default(cuid())
  unitId    String        @map("unit_id")
  amountAed Decimal       @map("amount_aed") @db.Decimal(10, 2)
  dueDate   DateTime      @map("due_date")
  status    InvoiceStatus @default(UNPAID)
  period    String
  year      Int

  unit     Unit      @relation(fields: [unitId], references: [id])
  payments Payment[]

  @@map("invoices")
}

model Payment {
  id              String   @id @default(cuid())
  invoiceId       String   @map("invoice_id")
  amount          Decimal  @db.Decimal(10, 2)
  stripePaymentId String?  @map("stripe_payment_id")
  paidAt          DateTime @default(now()) @map("paid_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}

model Ticket {
  id                String         @id @default(cuid())
  unitId            String         @map("unit_id")
  assignedTo        String?        @map("assigned_to")
  category          String
  priority          TicketPriority @default(MEDIUM)
  status            TicketStatus   @default(OPEN)
  dueDate           DateTime?      @map("due_date")
  satisfactionScore Int?           @map("satisfaction_score")

  unit        Unit              @relation(fields: [unitId], references: [id])
  assignee    User?             @relation("AssignedTickets", fields: [assignedTo], references: [id])
  comments    TicketComment[]
  attachments TicketAttachment[]

  @@map("tickets")
}

model TicketComment {
  id         String   @id @default(cuid())
  ticketId   String   @map("ticket_id")
  authorId   String   @map("author_id")
  body       String
  isInternal Boolean  @default(false) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id])
  author User   @relation(fields: [authorId], references: [id])

  @@map("ticket_comments")
}

model TicketAttachment {
  id       String @id @default(cuid())
  ticketId String @map("ticket_id")
  r2Key    String @map("r2_key")
  filename String

  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@map("ticket_attachments")
}

model Announcement {
  id       String    @id @default(cuid())
  authorId String    @map("author_id")
  title    String
  bodyHtml String    @map("body_html")
  audience Audience  @default(ALL)
  sentAt   DateTime? @map("sent_at")

  author User @relation(fields: [authorId], references: [id])

  @@map("announcements")
}

model RenovationApplication {
  id         String    @id @default(cuid())
  unitId     String    @map("unit_id")
  scope      String
  startDate  DateTime  @map("start_date")
  status     String    @default("PENDING")
  approvedBy String?   @map("approved_by")
  approvedAt DateTime? @map("approved_at")

  unit     Unit  @relation(fields: [unitId], references: [id])
  approver User? @relation("ApprovedRenovations", fields: [approvedBy], references: [id])

  @@map("renovation_applications")
}

model Violation {
  id            String    @id @default(cuid())
  unitId        String    @map("unit_id")
  ruleBreached  String    @map("rule_breached")
  evidenceR2Key String?   @map("evidence_r2_key")
  fineAmountAed Decimal?  @map("fine_amount_aed") @db.Decimal(10, 2)
  resolvedAt    DateTime? @map("resolved_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  unit Unit @relation(fields: [unitId], references: [id])

  @@map("violations")
}
